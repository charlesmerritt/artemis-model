   "source": [
    "## 3. Generate keyfiles\n",
    "\n",
    "Two bundles are written:\n",
    "\n",
    "- Linux/WSL bundle in the repo: `data/interim/fvs/smoke_no_management/`\n",
    "- Windows GUI bundle on `D:`: `D:\\TreeMap_Chaz\\artemis_fvs_smoke_no_management\\`\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "7c739365",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Linux manifest: /home/chazm/projects/artemis-model/data/interim/fvs/smoke_no_management/manifest.csv\n",
      "Windows manifest: /mnt/d/TreeMap_Chaz/artemis_fvs_smoke_no_management/manifest.csv\n"
     ]
    }
   ],
   "source": [
    "linux_manifest = write_smoke_keyfiles(\n",
    "    stands,\n",
    "    input_db=INPUT_DB,\n",
    "    out_dir=LINUX_OUT_DIR,\n",
    "    input_level=INPUT_LEVEL,\n",
    "    path_style=\"posix\",\n",
    "    overwrite=True,\n",
    ")\n",
    "windows_manifest = write_smoke_keyfiles(\n",
    "    stands,\n",
    "    input_db=INPUT_DB,\n",
    "    out_dir=WINDOWS_OUT_DIR,\n",
    "    input_level=INPUT_LEVEL,\n",
    "    path_style=\"windows\",\n",
    "    overwrite=True,\n",
    ")\n",
    "print(\"Linux manifest:\", linux_manifest.resolve())\n",
    "print(\"Windows manifest:\", windows_manifest.resolve())\n"
   ]
  },
