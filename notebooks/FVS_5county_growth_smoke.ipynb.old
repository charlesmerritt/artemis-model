   "source": [
    "def summarize_single_output_db(output_db: Path) -> dict[str, object]:\n",
    "    \"\"\"Return manifest-shaped QC summary rows for a single FVS output DB.\"\"\"\n",
    "    return {\n",
    "        \"stand_cn\": \"\",\n",
    "        \"stand_id\": output_db.stem,\n",
    "        \"input_level\": INPUT_LEVEL,\n",
    "        \"output_db\": str(output_db),\n",
    "        **summarize_output_db(output_db),\n",
    "    }\n",
    "\n",
    "\n",
    "FVS_OUTPUT_MANIFEST = linux_manifest if RUN_LOCAL_FVS else windows_manifest\n",
    "WINDOWS_OUTPUT_DB_ACTIVE = not RUN_LOCAL_FVS and WINDOWS_FVS_OUTPUT_DB.exists()\n",
    "FVS_OUTPUT_DIR = WINDOWS_FVS_OUTPUT_DB.parent if WINDOWS_OUTPUT_DB_ACTIVE else Path(FVS_OUTPUT_MANIFEST).parent\n",
    "\n",
    "if WINDOWS_OUTPUT_DB_ACTIVE:\n",
    "    print(\"Using Windows FVS output DB:\", WINDOWS_FVS_OUTPUT_DB)\n",
    "    summary_rows = [summarize_single_output_db(WINDOWS_FVS_OUTPUT_DB)]\n",
    "    summary_csv = FVS_OUTPUT_DIR / \"smoke_summary.csv\"\n",
    "else:\n",
    "    if not RUN_LOCAL_FVS:\n",
    "        print(\"Windows FVS output DB not found; falling back to Windows manifest outputs:\", WINDOWS_FVS_OUTPUT_DB)\n",
    "    summary_rows = summarize_manifest(FVS_OUTPUT_MANIFEST)\n",
    "    summary_csv = Path(FVS_OUTPUT_MANIFEST).with_name(\"smoke_summary.csv\")\n",
    "\n",
    "write_summary(summary_csv, summary_rows)\n",
    "summary_df = pd.DataFrame(summary_rows)\n",
    "print(\"Summarized source:\", WINDOWS_FVS_OUTPUT_DB if WINDOWS_OUTPUT_DB_ACTIVE else Path(FVS_OUTPUT_MANIFEST).resolve())\n",
    "print(\"Summary CSV:\", summary_csv.resolve())\n",
    "summary_df\n",
    ""
   ]
  },
