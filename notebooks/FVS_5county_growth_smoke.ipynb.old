    "def read_summary2_from_sqlite(output_db: Path) -> pd.DataFrame:\n",
    "    if not output_db.exists():\n",
    "        print(f\"FVS output DB not found: {output_db}\")\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    with sqlite3.connect(output_db) as con:\n",
    "        exists = con.execute(\n",
    "            \"SELECT 1 FROM sqlite_master WHERE type='table' AND name='FVS_Summary2'\"\n",
    "        ).fetchone()\n",
    "        if not exists:\n",
    "            tables = pd.read_sql_query(\n",
    "                \"SELECT name AS table_name FROM sqlite_master WHERE type='table' ORDER BY name\",\n",
    "                con,\n",
    "            )\n",
    "            print(f\"No FVS_Summary2 table found in {output_db}.\")\n",
    "            if not tables.empty:\n",
    "                print(\"Available tables:\")\n",
    "                if \"display\" in globals():\n",
    "                    display(tables)\n",
    "                else:\n",
    "                    print(tables.to_string(index=False))\n",
    "            return pd.DataFrame()\n",
    "        df = pd.read_sql_query(\"SELECT * FROM FVS_Summary2\", con)\n",
    "\n",
    "    df[\"source_output_db\"] = str(output_db)\n",
    "    return df\n",
    "\n",
    "\n",
    "def read_summary2_tables(manifest_path: Path) -> pd.DataFrame:\n",
    "    frames = []\n",
    "    with manifest_path.open(newline=\"\") as f:\n",
    "        for row in csv.DictReader(f):\n",
    "            output_db = Path(row[\"output_db\"])\n",
    "            if not output_db.exists():\n",
    "                continue\n",
    "            with sqlite3.connect(output_db) as con:\n",
    "                exists = con.execute(\n",
    "                    \"SELECT 1 FROM sqlite_master WHERE type='table' AND name='FVS_Summary2'\"\n",
    "                ).fetchone()\n",
    "                if not exists:\n",
    "                    continue\n",
    "                df = pd.read_sql_query(\"SELECT * FROM FVS_Summary2\", con)\n",
    "            df[\"manifest_stand_cn\"] = row[\"stand_cn\"]\n",
    "            df[\"manifest_stand_id\"] = row[\"stand_id\"]\n",
    "            df[\"source_output_db\"] = str(output_db)\n",
    "            frames.append(df)\n",
    "    return pd.concat(frames, ignore_index=True) if frames else pd.DataFrame()\n",
    "\n",
    "\n",
    "summary2_df = (\n",
    "    read_summary2_from_sqlite(WINDOWS_FVS_OUTPUT_DB)\n",
    "    if WINDOWS_OUTPUT_DB_ACTIVE\n",
    "    else read_summary2_tables(FVS_OUTPUT_MANIFEST)\n",
    ")\n",
    "print(f\"FVS_Summary2 rows: {len(summary2_df):,}\")\n",
    "summary2_df.head()\n",
    ""
   ]
  },
  {
   "cell_type": "markdown",
   "id": "48a706fd",
   "metadata": {},
   "source": [
    "## 6. DuckDB export and viewer\n",
    "\n",
    "This section converts `FVS_Summary2` into a DuckDB-friendly trajectory table:\n",
    "\n",
    "- column names become lower `snake_case`,\n",
    "- FIA/FVS IDs remain strings,\n",
    "- years/count-like fields are cast to integer where possible,\n",
    "- continuous stand metrics are cast to double where possible,\n",
    "- source manifest/output DB columns are retained for traceability.\n",
    "\n",
    "The notebook writes:\n",
    "\n",
    "- `fvs_summary2_duckdb.csv` — normalized interchange file\n",
    "- `fvs_summary2.duckdb` — DuckDB database with table `fvs_summary2`\n",
    "\n",
    "Then it starts DuckDB's web UI if `START_DUCKDB_UI = True`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "e5797ed5",
   "metadata": {},
   "outputs": [],
   "source": [
    "INTEGER_COLUMNS = {\n",
    "    \"year\", \"rmv_code\", \"age\", \"sdi\", \"ccf\", \"top_ht\", \"prd_len\",\n",
    "    \"for_typ\", \"size_cls\", \"stk_cls\",\n",
    "}\n",
    "STRING_COLUMNS = {\n",
    "    \"case_id\", \"stand_id\", \"manifest_stand_cn\", \"manifest_stand_id\", \"source_output_db\",\n",
    "}\n",
    "\n",
    "\n",
    "def duckdb_safe_column(name: str) -> str:\n",
    "    \"\"\"Convert an FVS/SQLite column name to a stable DuckDB-safe identifier.\"\"\"\n",
    "    cleaned = re.sub(r\"(.)([A-Z][a-z]+)\", r\"\\1_\\2\", str(name))\n",
    "    cleaned = re.sub(r\"([a-z0-9])([A-Z])\", r\"\\1_\\2\", cleaned)\n",
    "    cleaned = re.sub(r\"[^0-9A-Za-z]+\", \"_\", cleaned).strip(\"_\").lower()\n",
    "    return cleaned or \"column\"\n",
    "\n",
    "\n",
    "def make_unique_columns(columns: list[str]) -> list[str]:\n",
    "    seen: dict[str, int] = {}\n",
    "    unique = []\n",
    "    for column in columns:\n",
    "        base = duckdb_safe_column(column)\n",
    "        count = seen.get(base, 0)\n",
    "        unique.append(base if count == 0 else f\"{base}_{count + 1}\")\n",
    "        seen[base] = count + 1\n",
    "    return unique\n",
    "\n",
    "\n",
    "def summary2_to_duckdb_frame(summary2: pd.DataFrame) -> pd.DataFrame:\n",
    "    \"\"\"Normalize FVS_Summary2 rows for stable DuckDB loading.\"\"\"\n",
    "    if summary2.empty:\n",
    "        return summary2.copy()\n",
    "\n",
    "    df = summary2.copy()\n",
    "    df.columns = make_unique_columns(list(df.columns))\n",
    "\n",
    "    for column in df.columns:\n",
    "        if column in STRING_COLUMNS:\n",
    "            df[column] = df[column].astype(\"string\")\n",
    "        elif column in INTEGER_COLUMNS:\n",
    "            df[column] = pd.to_numeric(df[column], errors=\"coerce\").astype(\"Int64\")\n",
    "        else:\n",
    "            # Keep non-numeric object columns as strings; numeric metrics become floats.\n",
    "            numeric = pd.to_numeric(df[column], errors=\"coerce\")\n",
    "            if numeric.notna().any() or df[column].isna().all():\n",
    "                df[column] = numeric.astype(\"float64\")\n",
    "            else:\n",
    "                df[column] = df[column].astype(\"string\")\n",
    "\n",
    "    return df\n",
    "\n",
    "\n",
    "def sql_literal(path: Path) -> str:\n",
    "    return \"'\" + path.as_posix().replace(\"'\", \"''\") + \"'\"\n",
    "\n",
    "\n",
    "def duckdb_cast_expression(column: str) -> str:\n",
    "    quoted = f'\"{column}\"'\n",
    "    if column in STRING_COLUMNS:\n",
    "        return f\"CAST({quoted} AS VARCHAR) AS {quoted}\"\n",
    "    if column in INTEGER_COLUMNS:\n",
    "        return f\"TRY_CAST({quoted} AS INTEGER) AS {quoted}\"\n",
    "    return f\"TRY_CAST({quoted} AS DOUBLE) AS {quoted}\"\n",
    "\n",
    "\n",
    "def load_summary2_into_duckdb(\n",
    "    duckdb_df: pd.DataFrame,\n",
    "    *,\n",
    "    db_path: Path,\n",
    "    table_name: str = DUCKDB_TABLE,\n",
    ") -> Path | None:\n",
    "    \"\"\"Write normalized FVS_Summary2 to CSV and load it into DuckDB.\"\"\"\n",
    "    duckdb_cli = shutil.which(\"duckdb\")\n",
    "    if duckdb_cli is None:\n",
    "        raise FileNotFoundError(\"DuckDB CLI not found on PATH. Install DuckDB or add it to PATH.\")\n",
    "    if duckdb_df.empty:\n",
    "        print(\"No FVS_Summary2 rows found yet; skipping DuckDB load.\")\n",
    "        return None\n",
    "\n",
    "    db_path.parent.mkdir(parents=True, exist_ok=True)\n",
    "    csv_path = db_path.with_name(f\"{table_name}_duckdb.csv\")\n",
    "    duckdb_df.to_csv(csv_path, index=False)\n",
    "\n",
    "    select_list = \",\\n  \".join(duckdb_cast_expression(column) for column in duckdb_df.columns)\n",
    "    sql = f\"\"\"\n",
    "CREATE OR REPLACE TABLE {table_name} AS\n",
    "SELECT\n",
    "  {select_list}\n",
    "FROM read_csv_auto({sql_literal(csv_path)}, header=true, all_varchar=true);\n",
    "\n",
    "CREATE OR REPLACE VIEW {table_name}_preview AS\n",
    "SELECT * FROM {table_name} ORDER BY stand_id, year LIMIT 100;\n",
    "\n",
    "SELECT COUNT(*) AS rows_loaded FROM {table_name};\n",
    "\"\"\"\n",
    "    result = subprocess.run(\n",
    "        [duckdb_cli, str(db_path), \"-c\", sql],\n",
    "        text=True,\n",
    "        stdout=subprocess.PIPE,\n",
    "        stderr=subprocess.PIPE,\n",
    "        check=False,\n",
    "    )\n",
    "    if result.stdout:\n",
    "        print(result.stdout)\n",
    "    if result.returncode != 0:\n",
    "        raise RuntimeError(result.stderr)\n",
    "\n",
    "    print(\"DuckDB database:\", db_path.resolve())\n",
    "    print(\"DuckDB table:\", table_name)\n",
    "    print(\"DuckDB-ready CSV:\", csv_path.resolve())\n",
    "    return csv_path\n",
    "\n",
    "\n",
    "def preview_duckdb_table(db_path: Path, table_name: str = DUCKDB_TABLE) -> None:\n",
    "    duckdb_cli = shutil.which(\"duckdb\")\n",
    "    if duckdb_cli is None or not db_path.exists():\n",
    "        return\n",
    "    subprocess.run(\n",
    "        [duckdb_cli, str(db_path), \"-c\", f\"DESCRIBE {table_name}; SELECT * FROM {table_name}_preview;\"],\n",
    "        check=False,\n",
    "    )\n",
    "\n",
    "\n",
    "def start_duckdb_ui(db_path: Path) -> subprocess.Popen | None:\n",
    "    \"\"\"Start DuckDB's web UI for the loaded database in a background process.\"\"\"\n",
    "    duckdb_cli = shutil.which(\"duckdb\")\n",
    "    if duckdb_cli is None:\n",
    "        print(\"DuckDB CLI not found; cannot start UI.\")\n",
    "        return None\n",
    "    if not db_path.exists():\n",
    "        print(f\"DuckDB DB does not exist yet: {db_path}\")\n",
    "        return None\n",
    "\n",
    "    process = subprocess.Popen(\n",
    "        [duckdb_cli, \"-ui\", str(db_path)],\n",
    "        stdout=subprocess.DEVNULL,\n",
    "        stderr=subprocess.DEVNULL,\n",
    "    )\n",
    "    print(f\"Started DuckDB UI process {process.pid} for {db_path.resolve()}\")\n",
    "    print(\"If a browser did not open, run this manually:\")\n",
    "    print(f\"  duckdb -ui {db_path.resolve()}\")\n",
    "    return process\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "550b436f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "No FVS_Summary2 rows found yet; skipping DuckDB load.\n"
     ]
    }
   ],
   "source": [
    "duckdb_df = summary2_to_duckdb_frame(summary2_df)\n",
    "DUCKDB_DB = FVS_OUTPUT_DIR / \"fvs_summary2.duckdb\"\n",
    "loaded_csv = load_summary2_into_duckdb(duckdb_df, db_path=DUCKDB_DB, table_name=DUCKDB_TABLE)\n",
    "if loaded_csv is not None:\n",
    "    preview_duckdb_table(DUCKDB_DB, DUCKDB_TABLE)\n",
    "    duckdb_df.head()\n",
    ""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "7a168b49",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "DuckDB UI not started. Set START_DUCKDB_UI = True after loading data.\n"
     ]
    }
   ],
   "source": [
    "duckdb_ui_process = None\n",
    "if START_DUCKDB_UI and DUCKDB_DB.exists():\n",
    "    duckdb_ui_process = start_duckdb_ui(DUCKDB_DB)\n",
    "else:\n",
    "    print(\"DuckDB UI not started. Set START_DUCKDB_UI = True after loading data.\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7dadfc3d",
   "metadata": {},
   "source": [
    "## 7. Windows graphical FVS handoff\n",
    "\n",
    "Generated Windows-ready keyfiles are in:\n",
    "\n",
    "```text\n",
    "D:\\TreeMap_Chaz\\artemis_fvs_smoke_no_management\\\n",
    "```\n",
    "\n",
    "The Windows GUI run branch now reads Summary2/QC output from the FVS output database:\n",
    "\n",
    "```text\n",
    "C:\\FVS\\Artemis_project\\FVSOut.db\n",
    "```\n",
    "\n",
    "From WSL, that database is:\n",
    "\n",
    "```text\n",
    "/mnt/c/FVS/Artemis_project/FVSOut.db\n",
    "```\n",
    "\n",
    "`C:\\FVS\\Artemis_project\\FVS_Data.db` is the project/input database, not the Summary2 output database.\n",
    "\n",
    "Use this branch if the Linux shared-library path continues to fail.\n",
    "\n",
    "1. Start FVS OnLocal from `C:\\FVS\\FVSSoftware\\FVS.lnk` (or run `C:\\FVS\\FVSSoftware\\FVS_Icon.bat`).\n",
    "2. Open/use the existing project under `C:\\FVS\\Artemis_project\\`.\n",
    "3. Use the generated keyfiles if the GUI exposes a keyword/keyfile run option. Start with:\n",
    "   `D:\\TreeMap_Chaz\\artemis_fvs_smoke_no_management\\134677819010854\\134677819010854.key`\n",
