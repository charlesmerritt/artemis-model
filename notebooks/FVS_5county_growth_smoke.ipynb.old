   "source": [
    "probes = probe_variant_libraries(\n",
    "    PROJECT_ROOT / \"FVS/fvs-modern/lib\",\n",
    "    variant=\"SN\",\n",
    "    check_fvs2py=True,\n",
    "    fvs2py_path=FVS2PY_PATH,\n",
    ")\n",
    "pd.DataFrame([probe.__dict__ for probe in probes])\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9a77e42c",
   "metadata": {},
